PORT=5000
MONGODB_URI=
JWT_SECRET=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CORS_ORIGINS=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email: platform system sender (used for all applicant notifications)
# Example sender: joblens.portal@gmail.com
EMAIL_USER=
# Gmail App Password of EMAIL_USER (16 characters, no spaces)
EMAIL_APP_PASSWORD=
# Optional display name shown in "From"
EMAIL_FROM_NAME=JobLens Careers
# Optional support email shown in footer
APP_SUPPORT_EMAIL=
# Optional frontend/app URL shown in footer (also used as base for logo in emails: APP_URL/joblens-logo.png)
APP_URL=
# Optional: full URL to logo PNG for HTML emails (overrides APP_URL/joblens-logo.png)
EMAIL_LOGO_URL=

PORT=5000
MONGODB_URI=
JWT_SECRET=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CORS_ORIGINS=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email: platform system sender (used for all applicant notifications)
# Example sender: joblens.portal@gmail.com
EMAIL_USER=
# Gmail App Password of EMAIL_USER (16 characters, no spaces)
EMAIL_APP_PASSWORD=
# Optional: 465 (default) or 587 if your host blocks implicit SSL
# EMAIL_SMTP_PORT=587
# Optional display name shown in "From"
EMAIL_FROM_NAME=JobLens Careers
# Optional support email shown in footer
APP_SUPPORT_EMAIL=
# Optional frontend URL (footer; email logo fallback: APP_URL/joblens-logo.svg)
APP_URL=
# Optional public API base URL (email logo: API_PUBLIC_URL/email-assets/joblens-logo.png — no MIME attachment)
API_PUBLIC_URL=
# Optional: full URL to any hosted logo image for HTML emails (highest priority)
EMAIL_LOGO_URL=

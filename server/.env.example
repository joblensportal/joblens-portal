PORT=5000
MONGODB_URI=
JWT_SECRET=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CORS_ORIGINS=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email: applicant accept/reject notifications
#
# Recommended on Render / PaaS (outbound SMTP is often blocked): HTTPS API
# Resend — https://resend.com — free tier; get API key from dashboard
RESEND_API_KEY=
# Optional; default is Resend test sender (verify your domain for production)
# RESEND_FROM=JobLens Careers <onboarding@resend.dev>
#
# Or SendGrid — https://sendgrid.com — verified sender required
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=JobLens Careers
#
# Or Gmail SMTP (often blocked on cloud hosts)
# Example sender: joblens.portal@gmail.com
EMAIL_USER=
# Gmail App Password of EMAIL_USER (16 characters, no spaces)
EMAIL_APP_PASSWORD=
# Optional: force one port (otherwise tries 587 then 465 — better on Render / cloud)
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_PORT=465
# Optional SMTP hostname (default smtp.gmail.com)
# EMAIL_SMTP_HOST=smtp.gmail.com
# Optional display name shown in "From"
EMAIL_FROM_NAME=JobLens Careers
# Optional support email shown in footer
APP_SUPPORT_EMAIL=
# Optional frontend URL (footer; email logo fallback: APP_URL/joblens-logo.svg)
APP_URL=
# Optional public API base URL (email logo: API_PUBLIC_URL/email-assets/joblens-logo.png — no MIME attachment)
API_PUBLIC_URL=
# Optional: full URL to any hosted logo image for HTML emails (highest priority)
EMAIL_LOGO_URL=
